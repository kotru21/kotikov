# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/lighthouse-reports/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# superpowers brainstorm companion + staged review artifacts (local only)
.superpowers/
.cursor/
docs/
.agents/

# typescript
*.tsbuildinfo
next-env.d.ts

# Agent / IDE skill vendor copies (local only; do not commit)
.agent/
.agents/
.claude/
.codebuddy/
.codex/
.continue/
.gemini/
.kiro/
.opencode/
.qoder/
.roo/
.trae/
.windsurf/
.github/prompts/
skills-lock.json

# Python bytecode in vendored skill scripts
**/__pycache__/
*.pyc

# local git worktree checkouts
.worktrees/
